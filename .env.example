# F5 TV Streaming Platform
# Copy this file to .env.local for local development.

# Frontend for local Vite
APP_URL=http://localhost:3000
GEMINI_API_KEY=replace_me

# Hostinger PHP API mode
# In production, set VITE_API_URL to https://seudominio.com/api
VITE_USE_HOSTINGER_API=false
VITE_API_URL=http://localhost/f5tv/api

# Optional Node API mode for VPS/local experiments
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace_me_with_a_long_random_value
JWT_EXPIRES_IN=7d

# Optional PostgreSQL only for Node/VPS alternative
DATABASE_URL=postgres://user:password@localhost:5432/f5tv
DATABASE_SSL=false
SQL_DEBUG=false

# Hostinger MySQL credentials are configured in php-api/config.php after upload.
